# Kampüs Hub Environment Configuration Template
# Duplicate this file as '.env' and fill in the values.

# Supabase Local/Production Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google OAuth Credentials
GOOGLE_CLIENT_ID_ANDROID=your-google-android-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=your-google-ios-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=your-google-web-client-id.apps.googleusercontent.com

# Firebase Cloud Messaging Config
FIREBASE_SENDER_ID=123456789012
FIREBASE_API_KEY=AIzaSyA...
FIREBASE_PROJECT_ID=kampus-hub-fcm

# Google Drive Integration Config
GOOGLE_DRIVE_PARENT_FOLDER_ID=your-google-drive-parent-folder-id
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=your-base64-encoded-google-service-account-json
