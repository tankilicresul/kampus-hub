# Kampüs Hub Environment Configuration Template
# Duplicate this file as '.env' and fill in the values.
# NEVER commit the real .env file — it is in .gitignore.

# ── Supabase Local/Production Configuration ─────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google OAuth Credentials (used by supabase/config.toml) ─────────────────
# How to obtain:
#   1. Go to https://console.cloud.google.com/
#   2. Create (or select) a project → APIs & Services → Credentials
#   3. Create OAuth 2.0 Client IDs:
#      - Type: Web Application  → copy Client ID + Secret below
#      - Type: Android          → enter your app package name + SHA-1 fingerprint
#        SHA-1: run `cd apps/mobile/android && ./gradlew signingReport` (debug)
#   4. Set the Authorised redirect URI for the Web client to:
#      https://<your-project-id>.supabase.co/auth/v1/callback
#
# These values are read by Supabase local CLI via shell environment:
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-web-client-secret

# Android native Google Sign-In — Web Client ID (same as above, used in google-services.json)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# ── Firebase Cloud Messaging (optional — push notifications) ─────────────────
FIREBASE_SENDER_ID=123456789012
FIREBASE_API_KEY=AIzaSyA...
FIREBASE_PROJECT_ID=kampus-hub-fcm
